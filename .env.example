# Supabase Configuration
# Bu değerleri Supabase Dashboard > Settings > API kısmından alın
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google APIs
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Production-safe default is root domain. Keep callback path only if explicitly needed.
VITE_GOOGLE_OAUTH_REDIRECT_TO=/
VITE_GOOGLE_OAUTH_CALLBACK_PATH=/auth/google/callback
